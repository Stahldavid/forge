      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/forge-agent-ingest.cjs PostCompact",
            "timeout": 30,
            "statusMessage": "Recording Codex compaction result"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/forge-agent-ingest.cjs Stop",
            "timeout": 30,
            "statusMessage": "Recording Codex turn stop"
          }
        ]
      }
    ]
