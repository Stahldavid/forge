{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs SessionStart",
            "timeout": 3,
            "statusMessage": "Recording Codex session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs UserPromptSubmit",
            "timeout": 3,
            "statusMessage": "Recording Codex prompt metadata"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs PreToolUse",
            "timeout": 2,
            "statusMessage": "Recording Codex tool request"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs PermissionRequest",
            "timeout": 3,
            "statusMessage": "Recording Codex approval request"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs PostToolUse",
            "timeout": 2,
            "statusMessage": "Recording Codex tool result"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs SubagentStart",
            "timeout": 3,
            "statusMessage": "Recording Codex subagent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs SubagentStop",
            "timeout": 3,
            "statusMessage": "Recording Codex subagent stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs PreCompact",
            "timeout": 3,
            "statusMessage": "Recording Codex compaction start"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs PostCompact",
            "timeout": 3,
            "statusMessage": "Recording Codex compaction result"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .forge/agent/codex-hook.mjs Stop",
            "timeout": 3,
            "statusMessage": "Recording Codex turn stop"
          }
        ]
      }
    ]
  }
}
