{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/forge-agent-ingest.cjs SessionStart",
            "timeout": 30,
            "statusMessage": "Recording Codex session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/forge-agent-ingest.cjs UserPromptSubmit",
            "timeout": 30,
            "statusMessage": "Recording Codex prompt metadata"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/forge-agent-ingest.cjs PreToolUse",
            "timeout": 30,
            "statusMessage": "Recording Codex tool request"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/forge-agent-ingest.cjs PermissionRequest",
            "timeout": 30,
            "statusMessage": "Recording Codex approval request"
