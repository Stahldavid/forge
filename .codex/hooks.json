{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "forge agent ingest codex --event SessionStart",
            "timeout": 30,
            "statusMessage": "Recording Codex session start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
