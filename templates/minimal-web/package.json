{
  "name": "__FORGE_APP_NAME__",
  "private": true,
  "type": "module",
  "workspaces": [
    "web"
  ],
  "packageManager": "__PACKAGE_MANAGER__@1.3.14",
  "scripts": {
    "forge": "forge",
    "generate": "forge generate",
    "check": "forge check",
    "verify": "forge verify --strict",
    "dev": "forge dev",
    "dev:api": "forge dev --api-only",
    "dev:web": "cd web && __PACKAGE_MANAGER__ run dev",
    "typecheck": "tsc --noEmit && cd web && __PACKAGE_MANAGER__ run typecheck"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "forge": "__FORGE_PACKAGE_SPEC__"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "forge": {
    "template": "minimal-web",
    "sourceRoots": [
      "src"
    ]
  }
}
