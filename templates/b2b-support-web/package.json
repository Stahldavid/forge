{
  "name": "__FORGE_APP_NAME__",
  "private": true,
  "type": "module",
  "workspaces": [
    "web"
  ],
  "packageManager": "__PACKAGE_MANAGER_SPEC__",
  "scripts": {
    "forge": "forge",
    "generate": "forge generate",
    "verify": "forge verify --strict",
    "self-host:compose": "forge self-host compose",
    "self-host:check": "forge self-host check",
    "dev:api": "forge dev --api-only",
    "dev:web": "cd web && __PACKAGE_MANAGER__ run dev",
    "dev": "forge dev",
    "test": "node -e \"console.log('No tests configured')\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "forge": "__FORGE_PACKAGE_SPEC__",
    "zod": "^3.25.76"
