{
  "name": "basic-forge-app",
  "private": true,
  "type": "module",
  "forge": {
    "sourceRoots": ["src"]
  },
  "scripts": {
    "setup": "node ../../scripts/setup-example.mjs",
    "typecheck": "tsc --noEmit",
    "forge": "node ../../bin/forge.mjs",
    "forge:generate": "node ../../bin/forge.mjs generate",
    "forge:check": "node ../../bin/forge.mjs check",
    "forge:run": "node ../../bin/forge.mjs run",
    "forge:dev": "node ../../bin/forge.mjs dev --watch",
    "forge:dev:db": "node ../../bin/forge.mjs dev --watch --db pglite",
    "forge:db:migrate": "node ../../bin/forge.mjs db migrate --db pglite",
    "forge:db:reset": "node ../../bin/forge.mjs db reset --db pglite",
    "verify": "node ../../bin/forge.mjs verify"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "stripe": "^17.0.0",
    "posthog-js": "^1.200.0",
    "posthog-node": "^4.0.0"
  }
}
