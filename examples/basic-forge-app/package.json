{
  "name": "basic-forge-app",
  "private": true,
  "type": "module",
  "forge": {
    "sourceRoots": ["src"]
  },
  "scripts": {
    "setup": "node ../../scripts/setup-example.mjs",
    "typecheck": "tsc --noEmit",
    "forge:generate": "bun ../../src/forge/cli/main.ts generate",
    "forge:check": "bun ../../src/forge/cli/main.ts check",
    "forge:run": "bun ../../src/forge/cli/main.ts run",
    "forge:dev": "bun ../../src/forge/cli/main.ts dev --watch",
    "forge:dev:db": "bun ../../src/forge/cli/main.ts dev --watch --db pglite",
    "forge:db:migrate": "bun ../../src/forge/cli/main.ts db migrate --db pglite",
    "forge:db:reset": "bun ../../src/forge/cli/main.ts db reset --db pglite",
    "verify": "bun ../../src/forge/cli/main.ts verify"
  },
  "dependencies": {
    "zod": "^3.24.0",
    "stripe": "^17.0.0",
    "posthog-js": "^1.200.0",
    "posthog-node": "^4.0.0"
  }
}
