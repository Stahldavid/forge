{
  "name": "forgeos",
  "version": "0.1.0-alpha.50",
  "description": "Agent-native application framework and compiler for building Forge apps without a mandatory dashboard.",
  "type": "module",
  "license": "MIT",
  "files": [
    "adapters/",
    "!adapters/**/target/**",
    "!adapters/**/*.class",
    "!adapters/**/*.jar",
    "bin/",
    "scripts/field-test-forgeos.mjs",
    "docs/cair-protocol.md",
    "docs/forge-protocol.md",
    "examples/go-billing/",
    "examples/java-billing/",
    "!examples/**/target/**",
    "!examples/**/*.class",
    "!examples/**/*.jar",
    "packages/eslint-plugin-forge/",
    "schemas/",
    "src/",
    "!src/forge/_generated/**",
    "src/forge/_generated/releaseManifest.json",
    "src/forge/_generated/releaseManifest.ts",
    "templates/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "AGENTS.md",
    ".npmignore"
  ],
  "forge": {
    "sourceRoots": [
      "src"
    ]
  },
  "workspaces": [
    ".",
    "packages/*"
  ],
  "bin": {
    "forge": "bin/forge.mjs"
  },
  "exports": {
    "./react": "./src/forge/react/index.ts",
    "./vue": "./src/forge/vue/index.ts",
    "./server": "./src/forge/server.ts",
    "./policy": "./src/forge/policy.ts"
  },
  "scripts": {
    "test": "node ./bin/forge-bun.mjs test --timeout 120000",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "node scripts/version-packages.mjs",
    "release": "changeset publish",
    "release:pack": "npm pack --dry-run",
    "release:smoke": "node scripts/smoke-packed-package.mjs",
    "release:evidence": "node scripts/write-release-evidence.mjs",
    "release:verify-public-alpha": "node scripts/verify-public-alpha.mjs",
    "security:evidence": "node scripts/write-security-evidence.mjs",
    "security:deps": "node scripts/write-dependency-audit-evidence.mjs",
    "release:publish-alpha": "node scripts/publish-trusted-alpha.mjs",
    "release:publish-local-alpha": "node scripts/publish-local-alpha.mjs",
    "field:test": "node scripts/field-test-forgeos.mjs",
    "forge": "node ./bin/forge.mjs",
    "forge:node": "node ./bin/forge.mjs",
    "forge:bun": "node ./bin/forge-bun.mjs src/forge/cli/main.ts",
    "forge:check": "node ./bin/forge.mjs check",
    "forge:generate": "node ./bin/forge.mjs generate",
    "forge:generate:check": "node ./bin/forge.mjs generate --check",
    "lint": "node --import tsx ./src/forge/cli/lint-forge.ts",
    "verify": "node ./bin/forge.mjs verify",
    "example:setup": "node scripts/setup-example.mjs"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "engines": {
    "node": ">=22.14"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Stahldavid/forge.git"
  },
  "homepage": "https://forgeos.readthedocs.io/",
  "bugs": {
    "url": "https://github.com/Stahldavid/forge/issues"
  },
  "keywords": [
    "forgeos",
    "agent-native",
    "application-framework",
    "ai-agents",
    "full-stack",
    "cli"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.84",
    "@ai-sdk/openai": "^3.0.71",
    "@electric-sql/pglite": "^0.2.17",
    "ai": "^6.0.205",
    "jose": "^6.2.3",
    "postgres": "^3.4.5",
    "react": "^19.2.7",
    "tree-sitter": "^0.22.4",
    "tree-sitter-typescript": "^0.23.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "vue": "^3.5.38",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "1.3.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "fast-check": "^3.23.2",
    "react-test-renderer": "^19.2.7"
  },
  "overrides": {
    "read-yaml-file": "^3.0.0"
  }
}
