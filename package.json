{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "forge": {
    "sourceRoots": [
      "src"
    ]
  },
  "bin": {
    "forge": "./src/forge/cli/main.ts"
  },
  "scripts": {
    "test": "bun test --timeout 120000",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "forge": "bun src/forge/cli/main.ts",
    "forge:check": "bun run forge check",
    "forge:generate": "bun run forge generate",
    "forge:generate:check": "bun run forge generate --check",
    "lint": "bun src/forge/cli/lint-forge.ts",
    "verify": "bun run forge verify",
    "example:setup": "node scripts/setup-example.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@electric-sql/pglite": "^0.2.17",
    "ai": "^5.0.0",
    "jose": "^6.2.3",
    "react": "^19.2.7",
    "typescript": "^5.7.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "fast-check": "^3.23.2",
    "react-test-renderer": "^19.2.7",
    "tree-sitter": "^0.22.4",
    "tree-sitter-typescript": "^0.23.2"
  }
}
