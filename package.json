{
  "name": "forge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "forge": {
    "sourceRoots": ["src"]
  },
  "bin": {
    "forge": "./src/forge/cli/main.ts"
  },
  "scripts": {
    "test": "bun test",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "forge": "bun src/forge/cli/main.ts",
    "forge:check": "bun run forge check",
    "forge:generate": "bun run forge generate",
    "forge:generate:check": "bun run forge generate --check",
    "lint": "bun src/forge/cli/lint-forge.ts",
    "verify": "bun run forge verify",
    "example:setup": "node scripts/setup-example.mjs"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "fast-check": "^3.23.2",
    "tree-sitter": "^0.22.4",
    "tree-sitter-typescript": "^0.23.2"
  }
}
